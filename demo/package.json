{
  "name": "@polydraw/public-demo-workspace",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:wrapper": "npm run dev --workspace @polydraw-demo/wrapper",
    "dev:wrapper:local": "npm run dev:local --workspace @polydraw-demo/wrapper",
    "dev:v1": "npm run dev --workspace @polydraw-demo/leaflet-v1",
    "dev:v1:local": "npm run dev:local --workspace @polydraw-demo/leaflet-v1",
    "dev:v2": "npm run dev --workspace @polydraw-demo/leaflet-v2",
    "dev:v2:local": "npm run dev:local --workspace @polydraw-demo/leaflet-v2",
    "build:wrapper": "npm run build --workspace @polydraw-demo/wrapper",
    "build:wrapper:local": "npm run build:local --workspace @polydraw-demo/wrapper",
    "build:v1": "npm run build --workspace @polydraw-demo/leaflet-v1",
    "build:v1:local": "npm run build:local --workspace @polydraw-demo/leaflet-v1",
    "build:v2": "npm run build --workspace @polydraw-demo/leaflet-v2",
    "build:v2:local": "npm run build:local --workspace @polydraw-demo/leaflet-v2",
    "build": "npm run build:wrapper && npm run build:v1 && npm run build:v2 && node ./scripts/stage-dist.mjs",
    "build:local": "npm run build:wrapper:local && npm run build:v1:local && npm run build:v2:local && node ./scripts/stage-dist.mjs",
    "clean": "rm -rf dist apps/wrapper/dist apps/leaflet-v1/dist apps/leaflet-v2/dist"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.18",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
